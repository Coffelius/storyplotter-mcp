# Copy to .env and fill in. Never commit .env.
# These vars are consumed by the binary and by docker-compose.yml.

# Legacy single-file corpus. Used as the read-only fallback when
# X-LibreChat-User-Id is absent (smoke tests, stdio mode, anonymous probes).
STORYPLOTTER_DATA_PATH=/data/storyplotter.json

# Per-user JSON root. The DiskUserStore reads/writes
# <STORYPLOTTER_DATA_DIR>/<userID>/storyplotter.json for each authenticated
# LibreChat user. Default: /data/users.
STORYPLOTTER_DATA_DIR=/data/users

# Shared bearer required on every HTTP request. Must match the value
# LibreChat sends in its Authorization header.
# Generate with:  openssl rand -hex 32
MCP_BEARER=change-me-before-deploy

# HMAC key used to sign /download links. Hex-encoded, decodes to >=16 bytes.
# Generate with:  openssl rand -hex 32
DOWNLOAD_SIGNING_KEY=change-me-generate-with-openssl-rand-hex-32

# Public base URL of this MCP (used to build /download links).
MCP_PUBLIC_URL=https://mcp-storyplotter.gabi.tv

# Max request body size for /mcp (bytes). Applied by GAB-97.
MCP_BODY_LIMIT_BYTES=5242880
